# pubmed-reference-resolver — API Key 設定テンプレート
#
# 使い方:
#   1. このファイルをコピーして ".env" にリネーム
#        cp .env.example .env
#   2. 下の <...> を自分のキーに置き換え
#   3. 保存して実行 (python3 main.py ... または Claude スキル経由)
#
# 配置場所 (以下のいずれか、先頭にあるほど優先):
#   A. {スキル配置ディレクトリ}/.env
#        例: ~/.claude/skills/pubmed-reference-resolver/.env
#   B. $HOME/.pubmed-reference-resolver.env
#        例: /Users/yourname/.pubmed-reference-resolver.env (ホーム直下・隠しファイル)
#   C. {カレントディレクトリ}/.env
#        例: 作業中のフォルダに置く
#   D. {入力PDFと同じディレクトリ}/.env
#        例: 査読対象の論文フォルダに置く
#
# 親プロセスで既に export 済みの値は .env より優先されます (上書きなし)。
# CLI 引数 --api-key / --ncbi-api-key は最優先です。

# ===== Anthropic API Key (必須) =====
# console.anthropic.com/settings/keys で取得
# sk-ant-api03-... で始まる
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-WITH-YOUR-KEY

# ===== NCBI API Key (任意、推奨) =====
# https://account.ncbi.nlm.nih.gov/settings/ → API Key Management
# 設定すると PubMed が 10 req/sec (無ければ 3 req/sec)
NCBI_API_KEY=REPLACE-WITH-YOUR-NCBI-KEY
